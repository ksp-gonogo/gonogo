{
  "name": "gonogo",
  "license": "MIT",
  "private": true,
  "scripts": {
    "dev": "sh scripts/dev.sh",
    "dev:rebuild": "BUILD=1 sh scripts/dev.sh",
    "dev:logs": "ENABLE_AXIOM=1 sh scripts/dev.sh",
    "play": "sh scripts/play.sh",
    "prepare": "git config core.hooksPath .githooks || true",
    "build": "turbo build",
    "codegen": "bash mod/codegen.sh",
    "codegen:check": "bash mod/codegen.sh && git diff --exit-code -- mod/sitrep-sdk/src/__generated__",
    "test": "turbo test",
    "test:playwright": "playwright test",
    "typecheck": "turbo typecheck",
    "coverage": "vitest run --coverage",
    "lint": "biome check --write .",
    "release:patch": "node scripts/release.mjs patch",
    "release:minor": "node scripts/release.mjs minor",
    "release:major": "node scripts/release.mjs major"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.12",
    "@grpc/grpc-js": "^1.12.2",
    "@grpc/proto-loader": "^0.7.13",
    "@playwright/test": "^1.60.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@types/ws": "^8.0.0",
    "@vitejs/plugin-react": "^4.0.0",
    "@vitest/coverage-v8": "^4.1.4",
    "jpeg-js": "^0.4.4",
    "jsdom": "^29.0.2",
    "peer": "^1.0.2",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "turbo": "latest",
    "typescript": "^5.0.0",
    "vitest": "^4.1.4",
    "ws": "^8.21.0"
  },
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@10.0.0",
  "pnpm": {
    "overrides": {
      "@types/react": "^18.3.28",
      "@types/react-dom": "^18.3.7"
    },
    "onlyBuiltDependencies": [
      "node-pty",
      "@roamhq/wrtc"
    ]
  }
}
