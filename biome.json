{
  "$schema": "https://biomejs.dev/schemas/2.4.12/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "ignoreUnknown": false,
    "includes": [
      "**",
      "!**/test/recorded_fixtures",
      "!**/dist",
      "!.claude",
      "!**/__generated__",
      "!docs/homepage"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space"
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "nursery": {
        "useBaseline": {
          "level": "error",
          "options": { "available": "newly" }
        }
      },
      "style": {
        "noRestrictedImports": {
          "level": "warn",
          "options": {
            "paths": {
              "@testing-library/react": {
                "importNames": ["cleanup"],
                "message": "Testing Library auto-cleans after every test — a manual cleanup import/call is redundant and masks real teardown bugs. Remove it and rely on automatic cleanup."
              }
            }
          }
        }
      }
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "double"
    }
  },
  "assist": {
    "enabled": true,
    "actions": {
      "source": {
        "organizeImports": "on"
      }
    }
  },
  "overrides": [
    {
      "includes": [
        "packages/components/src/**",
        "mod/*/client/src/**",
        "!packages/ui/**",
        "!packages/ui-kit/**"
      ],
      "linter": {
        "rules": {
          "style": {
            "noRestrictedImports": {
              "level": "warn",
              "options": {
                "paths": {
                  "styled-components": {
                    "message": "Migrated widgets carry zero bespoke CSS — compose @ksp-gonogo/ui-kit primitives + layout + tokens instead. See local_docs/telemetry-mod/ui-kit-design.md."
                  },
                  "@testing-library/react": {
                    "importNames": ["cleanup"],
                    "message": "Testing Library auto-cleans after every test — a manual cleanup import/call is redundant and masks real teardown bugs. Remove it and rely on automatic cleanup."
                  }
                }
              }
            }
          }
        }
      }
    }
  ]
}
