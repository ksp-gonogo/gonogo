#!/bin/sh
# Lint/format + typecheck the workspace before every commit.
#
# Why: the test suite covers neither — vitest runs through esbuild (no type
# checking) and biome lint/format isn't a test — so tsc-only errors and format
# drift only surfaced in CI, and a batch slipped onto main while CI was blocked
# at install. biome is sub-second on the whole repo; `turbo typecheck` caches
# per package, so unchanged packages are instant.
#
# `biome check` here is verify-only (no --write): auto-fixing mid-commit
# wouldn't make it into the staged snapshot. If it fails on formatting, run
# `pnpm lint` to auto-fix, then re-commit. Bypass in a pinch: git commit --no-verify
echo "pre-commit: biome check + pnpm typecheck…"
pnpm exec biome check . && pnpm typecheck
