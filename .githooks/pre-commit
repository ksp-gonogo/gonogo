#!/bin/sh
# Typecheck the workspace before every commit.
#
# Why: vitest runs through esbuild and does NOT type-check, so tsc-only errors
# (e.g. a styled-component missing a prop in its generic) pass tests locally
# and only surface in CI's build step. While CI was blocked at install, a batch
# of those slipped onto main. `turbo typecheck` caches per package, so unchanged
# packages are instant — only what you touched re-runs.
#
# Bypass in a pinch with: git commit --no-verify
echo "pre-commit: pnpm typecheck…"
pnpm typecheck
