# Workspace deps are copied into each consuming package's node_modules
# (rather than symlinked) so `pnpm deploy` can produce a self-contained
# /app directory for Docker images. Symlinks would point outside the
# image build context and break at runtime.
inject-workspace-packages=true

# @ksp-gonogo/kerbcast + @ksp-gonogo/kerbcast-react (the kerbcast protocol
# bindings, consumed by @ksp-gonogo/kerbcast-feed) resolve from public npm —
# no scoped registry routing or auth needed.
