# Workspace deps are copied into each consuming package's node_modules
# (rather than symlinked) so `pnpm deploy` can produce a self-contained
# /app directory for Docker images. Symlinks would point outside the
# image build context and break at runtime.
inject-workspace-packages=true

# kerbcast protocol bindings (@jonpepler/kerbcast) live on GitHub
# Packages, not npmjs.com. Authenticated reads even for public
# packages: in CI the auto-injected secrets.GITHUB_TOKEN works;
# locally, either export GITHUB_TOKEN with a `read:packages`-scoped
# PAT or rely on `gh auth token`'s stored value.
@jonpepler:registry=https://npm.pkg.github.com
//npm.pkg.github.com/:_authToken=${GITHUB_TOKEN}
