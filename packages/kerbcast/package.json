{
  "name": "@gonogo/kerbcast",
  "license": "GPL-3.0-only",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "render-camera": "TSX_TSCONFIG_PATH=tsconfig.json tsx scripts/render-camera.ts"
  },
  "dependencies": {
    "@gonogo/core": "workspace:*",
    "@gonogo/logger": "workspace:*",
    "@gonogo/sitrep-client": "workspace:*",
    "@gonogo/ui": "workspace:*",
    "@jonpepler/kerbcast": "^1.4.0",
    "@jonpepler/kerbcast-react": "^1.4.0",
    "styled-components": "^6.0.0"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.2",
    "@types/react": "^18.3.28",
    "@vitest/coverage-v8": "^4.1.4",
    "esbuild": "^0.28.0",
    "jsdom": "^29.0.2",
    "playwright": "^1.60.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "vitest": "^4.1.4"
  },
  "peerDependencies": {
    "react": "^18.0.0"
  }
}
