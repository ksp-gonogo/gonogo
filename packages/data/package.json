{
  "name": "@ksp-gonogo/data",
  "license": "GPL-3.0-only",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./replay": {
      "types": "./src/replay-entry.ts",
      "default": "./src/replay-entry.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@ksp-gonogo/core": "workspace:*",
    "@ksp-gonogo/logger": "workspace:*",
    "@ksp-gonogo/sitrep-client": "workspace:*",
    "@ksp-gonogo/ui": "workspace:*"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.2",
    "@types/react": "^18.3.28",
    "@vitest/coverage-v8": "^4.1.4",
    "fake-indexeddb": "^6.0.0",
    "jsdom": "^29.0.2",
    "typescript": "^5.0.0",
    "vitest": "^4.1.4"
  },
  "peerDependencies": {
    "react": "^18.0.0",
    "styled-components": "^6.0.0"
  }
}
