{
  "name": "@ksp-gonogo/ui-kit",
  "description": "Export-safe design system for Gonogo mission-control widgets and third-party Uplinks",
  "license": "GPL-3.0-only",
  "version": "0.1.0",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ksp-gonogo/gonogo.git",
    "directory": "packages/ui-kit"
  },
  "homepage": "https://github.com/ksp-gonogo/gonogo/tree/main/packages/ui-kit#readme",
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": [
    "*.css"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.test-d.json"
  },
  "dependencies": {
    "@ksp-gonogo/theme": "workspace:*"
  },
  "devDependencies": {
    "@ksp-gonogo/sitrep-sdk": "workspace:*",
    "@ksp-gonogo/test-utils": "workspace:*",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest-axe": "^3.5.9",
    "@types/react": "^18.0.0",
    "jest-axe": "^10.0.0",
    "jsdom": "^29.0.2",
    "typescript": "^5.0.0",
    "vitest": "^4.1.4"
  },
  "peerDependencies": {
    "react": "^18.0.0",
    "styled-components": "^6.0.0"
  }
}
