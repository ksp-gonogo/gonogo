exports[`OrbitView DOM snapshots > sub-orbital-kerbin @ square-5x5 1`] = `"<div><div><h3>ORBIT VIEW</h3><span role="status" aria-live="polite">OFFLINE</span></div><div>Kerbin</div><div><svg viewBox="-1301500 -1301500 2603000 2603000" preserveAspectRatio="xMidYMid meet" role="img" aria-label="Orbital diagram"><g transform="rotate(0)"><ellipse cx="-221400.00000000003" cy="0" rx="820000" ry="789545.464175433" fill="none" stroke="rgba(255,80,0,0.55)" stroke-width="14565.6"></ellipse></g><circle cx="0" cy="0" r="670000" fill="rgba(80, 160, 220, 0.18)"></circle><circle cx="0" cy="0" r="600000" fill="#1A6B8A"></circle><g transform="rotate(0)"><circle cx="-1040400" cy="0" r="29131.2" fill="var(--color-status-warning-bg)" aria-label="Apoapsis altitude 440.4 km" tabindex="0" role="img" style="--apsis-focus-stroke-w: 14565.6px;"></circle><circle cx="599600" cy="0" r="29131.2" fill="var(--color-tag-blue-fg)" aria-label="Periapsis altitude -400 m" tabindex="0" role="img" style="--apsis-focus-stroke-w: 14565.6px;"></circle><circle cx="482555.84771491867" cy="404912.43384002824" r="43696.8" fill="var(--color-accent-fg)"></circle></g><g pointer-events="none"><g transform="translate(-1113228, 0) scale(1)"><text x="0" y="0" text-anchor="middle" dominant-baseline="middle" fill="var(--color-status-warning-bg)" font-size="16" style="paint-order: stroke; stroke: var(--color-surface-app); stroke-width: 2.88; stroke-linejoin: round; user-select: none;">Ap</text></g><g transform="translate(672428, 0) scale(1)"><text x="0" y="0" text-anchor="middle" dominant-baseline="middle" fill="var(--color-tag-blue-fg)" font-size="16" style="paint-order: stroke; stroke: var(--color-surface-app); stroke-width: 2.88; stroke-linejoin: round; user-select: none;">Pe</text></g></g></svg></div></div>"`;
