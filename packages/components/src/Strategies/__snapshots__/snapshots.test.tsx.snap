exports[`Strategies DOM snapshots > at-admin-cap @ compact-5x7 1`] = `"<div><div><h3>Admin Building</h3><div><span>2 active</span></div></div><div><div><section aria-label="Active"><h4>Active</h4><article><div><div>Aggressive Negotiations</div><span>Operations</span></div><p>Push harder on every deal.</p><ul><li>-1.5% Funds Off on Launch Costs and R&amp;D Purchases.</li><li>-0.05% Funds Off on Facility Repair and Construction.</li></ul><div><span>factor 25%</span><button type="button" title="Deactivate this strategy">Deactivate</button></div></article><article><div><div>Open Source Tech</div><span>Research &amp; Development</span></div><p>Share technologies with research institutes in exchange for science.</p><ul><li>Converts 5% of Funds earned into Science points.</li></ul><div><span>factor 15%</span><button type="button" title="Deactivate this strategy">Deactivate</button></div></article></section><section aria-label="Available"><h4>Available</h4><article><div><div>Fundraising Campaign</div><span>Finances</span></div><p>Deactivate the running strategy first to enable this one.</p></article></section></div><div></div><div></div></div></div>"`;

