// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`RoboticsConsole DOM snapshots > servos @ default-5x8 1`] = `"<div><h3>ROBOTICS</h3><div><div><span>22<span>°</span></span><span aria-hidden="true">→</span><span>60<span>°</span></span><span role="status">MOVING</span></div><div><div><span>Target</span><div><button type="button" aria-label="Decrease target">−</button><span>60°</span><button type="button" aria-label="Increase target">+</button></div></div><div><button type="button" aria-pressed="true">Motor on</button><button type="button" aria-pressed="false">Unlocked</button></div></div><div aria-label="Robotic joints"><button type="button" aria-pressed="true"><span>Arm Hinge</span><span>hinge · 22°/60°</span></button><button type="button" aria-pressed="false"><span>Deploy Piston</span><span>piston · 80%/80% · ✓</span></button><button type="button" aria-pressed="false"><span>Base Rotator</span><span>rotation · 0°/0° · locked</span></button></div></div></div>"`;

