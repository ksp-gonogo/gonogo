<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <LangVersion>latest</LangVersion>
    <IsPackable>false</IsPackable>
    <IsTestProject>true</IsTestProject>
  </PropertyGroup>
  <ItemGroup>
    <PackageReference Include="Microsoft.NET.Test.Sdk" Version="17.11.1" />
    <PackageReference Include="xunit" Version="2.9.2" />
    <PackageReference Include="xunit.runner.visualstudio" Version="2.8.2">
      <PrivateAssets>all</PrivateAssets>
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
    </PackageReference>
  </ItemGroup>
  <ItemGroup>
    <!-- Sitrep.Contract is the pure-DTO/SPI assembly KosExtension's KSP-free
         half compiles against (UplinkManifest, ISitrepUplink, IUplinkHost,
         CommandResult, the Kos*Args types, ...) — netstandard2.0;net472, no
         KSP/Unity linkage. Mirrors GonogoScansatUplink.Tests's split.
         Sitrep.Host (KosExtensionDiscoveryTests's UplinkDiscovery) is the
         same story — its own csproj declares a zero-external-dependency,
         KSP-free invariant. -->
    <ProjectReference Include="../Sitrep.Contract/Sitrep.Contract.csproj" />
    <ProjectReference Include="../Sitrep.Host/Sitrep.Host.csproj" />
  </ItemGroup>
  <ItemGroup>
    <!-- Only the KSP/Unity/kOS-type-free half of GonogoKosUplink is exercised
         here — net10.0, no kOS.dll/UnityEngine.dll reference assemblies
         needed, same headless-test split as GonogoScansatUplink/
         GonogoScansatUplink.Tests. KosExtension.cs itself is split into a
         KSP-free half (this file) and a KSP-touching half
         (KosExtension.Ksp.cs, NOT included below) via `partial class` — see
         KosExtension.cs's class doc comment for the seam
         (InstallProductionDefaults). KosMainThreadDispatcherAddon (touches
         UnityEngine/GameObject), KosComputeHarmony (touches kOS.Safe.Screen +
         Harmony), and KosProcessorScreen (touches kOS.Module/kOS.Safe.Screen/
         kOS.Screen/kOS.UserIO) are deliberately NOT included — nothing this
         project needs reaches them (see MainThreadDispatcherTests's doc
         comment: a real GameObject can't be created outside a live Unity
         process, and this project must not instantiate those types
         directly). -->
    <Compile Include="..\GonogoKosUplink\KosChannels.cs" />
    <Compile Include="..\GonogoKosUplink\KosComputeAccumulator.cs" />
    <Compile Include="..\GonogoKosUplink\KosDataParser.cs" />
    <Compile Include="..\GonogoKosUplink\KosVersionGuard.cs" />
    <!-- KosExtension.cs's IUplinkHealthReporter.Health() state machine — pure
         function, no kOS/Unity types, mirrors KerbcastHealth.cs. -->
    <Compile Include="..\GonogoKosUplink\KosHealth.cs" />
    <Compile Include="..\GonogoKosUplink\KosTerminalManager.cs" />
    <Compile Include="..\GonogoKosUplink\KosRunManager.cs" />
    <Compile Include="..\GonogoKosUplink\MainThreadDispatcher.cs" />
    <Compile Include="..\GonogoKosUplink\KosExtension.cs" />
    <!-- KosExtension.cs's HandleProcessors flattens through this at the
         publish boundary (see its own doc comment). -->
    <Compile Include="..\GonogoKosUplink\KosProcessorInfoBuilder.cs" />
    <!-- KosTerminalFrameBuilder/KosRunResultBuilder are used in production
         only from KosExtension.Ksp.cs (the KSP-touching half, deliberately
         NOT included in this project) — included here anyway because the
         Builders themselves are pure Dictionary mappers with no kOS/Unity
         dependency, so their own wire-shape tests
         (KosTerminalFrameBuilderTests/KosRunResultBuilderTests) can run
         headlessly. -->
    <Compile Include="..\GonogoKosUplink\KosTerminalFrameBuilder.cs" />
    <Compile Include="..\GonogoKosUplink\KosRunResultBuilder.cs" />
    <!-- Generated by mod/scripts/bake-client-hash.mjs; referenced by the manifest above. -->
    <Compile Include="..\GonogoKosUplink\ExpectedClientHash.g.cs" />
  </ItemGroup>

  <!-- Headless kOS terminal harness (GonogoKosUplink.Tests/Headless/) — the ONE
       part of this project that drives the REAL kOS.Safe screen pipeline
       (ScreenBuffer -> ScreenSnapShot.DiffFrom -> TerminalXtermMapper) end to
       end through a real Courier. It needs kOS.Safe.dll + kOS.dll, resolved
       from a KSP install / the ksp-managed reference set exactly the way the
       KSP-facing mod csprojs resolve them (KspGameData, overridable with
       /p:KspGameData=...). Both DLLs are genuinely loadable in a plain .NET
       process — kOS.Safe is Unity-free by design, and the mapper's body touches
       only mscorlib + kOS.Safe types, so kOS.dll's UnityEngine references stay
       lazily unresolved (verified: see the harness report).

       SOFT-DEGRADE: when those DLLs are absent (a stock CI runner today), the
       kOS references, the extracted ScreenDiffMapper source, and the whole
       Headless/ folder are dropped and a build warning is emitted, so the
       KSP-free suite still builds and passes — the visual-gate soft-pass model.
       The CI job supplies the DLLs by checking out ksp-gonogo/ksp-managed and
       passing /p:KspGameData; see .github/workflows/ci.yml's mod job and
       docs/superpowers/plans/2026-07-13-kos-headless-harness-report.md. -->
  <PropertyGroup>
    <KspGameData Condition="'$(KspGameData)' == ''">$(MSBuildThisFileDirectory)..\..\local_docs\syncthing\kspdata\GameData</KspGameData>
    <KosSafeDll>$(KspGameData)\kOS\Plugins\kOS.Safe.dll</KosSafeDll>
    <KosDll>$(KspGameData)\kOS\Plugins\kOS.dll</KosDll>
    <KosSafeAvailable Condition="Exists('$(KosSafeDll)') And Exists('$(KosDll)')">true</KosSafeAvailable>
  </PropertyGroup>

  <!-- The SDK auto-globs Headless/**; drop it unless the kOS DLLs are present. -->
  <ItemGroup>
    <Compile Remove="Headless\**\*.cs" />
  </ItemGroup>

  <ItemGroup Condition="'$(KosSafeAvailable)' == 'true'">
    <Reference Include="kOS.Safe">
      <HintPath>$(KosSafeDll)</HintPath>
    </Reference>
    <Reference Include="kOS">
      <HintPath>$(KosDll)</HintPath>
    </Reference>
    <Compile Include="..\GonogoKosUplink\ScreenDiffMapper.cs" />
    <Compile Include="Headless\**\*.cs" />
  </ItemGroup>

  <Target Name="WarnKosHarnessSkipped" BeforeTargets="Build" Condition="'$(KosSafeAvailable)' != 'true'">
    <Warning Text="kOS.Safe.dll / kOS.dll not found under KspGameData=$(KspGameData) — the headless kOS terminal harness (GonogoKosUplink.Tests/Headless) is SKIPPED. Pass /p:KspGameData=&lt;GameData containing kOS/Plugins&gt; to compile and run it." />
  </Target>
</Project>
