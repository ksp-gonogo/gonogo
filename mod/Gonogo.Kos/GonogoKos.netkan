{
  "spec_version": 1,
  "identifier": "GonogoKos",
  "name": "Gonogo kOS Uplink",
  "abstract": "Bridges kOS to the Gonogo telemetry connection, exposing kos.* channels and commands (processors, compute, files, terminal) in-process.",
  "author": "jonpepler",
  "license": "GPL-3.0-only",
  "release_status": "development",
  "resources": {
    "homepage": "https://github.com/ksp-gonogo/gonogo"
  },
  "tags": [
    "plugin",
    "telemetry",
    "kos"
  ],
  "depends": [
    { "name": "GonogoCore" },
    { "name": "kOS" }
  ],
  "install": [
    {
      "file": "GameData/GonogoKos",
      "install_to": "GameData"
    }
  ]
}
