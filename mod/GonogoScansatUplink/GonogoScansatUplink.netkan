  "license": "GPL-3.0-only",
  "release_status": "development",
  "resources": {
    "homepage": "https://github.com/ksp-gonogo/gonogo"
  },
  "tags": [
    "plugin",
    "telemetry",
    "scansat"
  ],
  "depends": [
    { "name": "GonogoCore" },
    { "name": "SCANsat" }
  ],
  "install": [
    {
      "file": "GameData/GonogoScansatUplink",
      "install_to": "GameData"
    }
  ]
}
