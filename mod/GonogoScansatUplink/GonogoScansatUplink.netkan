{
  "spec_version": 1,
  "identifier": "GonogoScansatUplink",
  "name": "Gonogo SCANsat Uplink",
  "abstract": "Streams SCANsat coverage/anomaly/vessel data as scansat.* channels over the Gonogo telemetry connection.",
